<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /forafix/

    # 1. If the request is for an existing file/dir in the root OR public folder, serve it.
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # 2. Check if the file exists in the public directory and serve it if found
    RewriteCond %{DOCUMENT_ROOT}/forafix/public/$1 -f
    RewriteRule ^(.*)$ public/$1 [L]

    # 3. Otherwise, send all virtual routes to public/index.php
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.*)$ public/index.php [L]
</IfModule>
